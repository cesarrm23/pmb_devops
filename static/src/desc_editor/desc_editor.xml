<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pmb_devops.DevopsDescEditor">
        <div class="pmb-desc-editor">
            <div class="pmb-desc-editor-shell"
                 style="background: #11111b; border: 1px solid #45475a; border-radius: 4px; min-height: 220px;">
                <Wysiwyg config="config" onLoad.bind="onWysiwygLoad"/>
            </div>
            <div class="mt-2 d-flex gap-2">
                <button class="btn btn-sm"
                        style="background: #a6e3a1; color: #1e1e2e; font-size: 11px; font-weight: 600;"
                        t-att-disabled="internal.busy"
                        t-on-click="_save">Guardar</button>
                <button class="btn btn-sm"
                        style="background: #313244; color: #cdd6f4; font-size: 11px;"
                        t-on-click="_cancel">Cancelar</button>
            </div>
        </div>
    </t>

</templates>
