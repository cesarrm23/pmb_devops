<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="ir.cron" id="cron_auto_backup">
            <field name="name">PMB DevOps: Backup Automático</field>
            <field name="model_id" ref="pmb_devops.model_devops_backup"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_backup()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
        <record model="ir.cron" id="cron_check_status">
            <field name="name">PMB DevOps: Verificar Estado de Servicios</field>
            <field name="model_id" ref="pmb_devops.model_devops_project"/>
            <field name="state">code</field>
            <field name="code">
for p in model.search([('odoo_service_name', '!=', False)]):
    p._compute_state()
            </field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
