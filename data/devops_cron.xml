<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="ir.cron" id="cron_auto_backup">
            <field name="name">PMB DevOps: Backup Automático</field>
            <field name="model_id" ref="pmb_devops.model_devops_backup"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_backup()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
        <record model="ir.cron" id="cron_check_status">
            <field name="name">PMB DevOps: Verificar Estado de Servicios</field>
            <field name="model_id" ref="pmb_devops.model_devops_project"/>
            <field name="state">code</field>
            <field name="code">
for p in model.search([('odoo_service_name', '!=', False)]):
    p._compute_state()
            </field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Server metrics: collect disk/memory/CPU every 5 min -->
        <record model="ir.cron" id="cron_server_metrics">
            <field name="name">PMB DevOps: Recolectar metricas del servidor</field>
            <field name="model_id" ref="pmb_devops.model_devops_project"/>
            <field name="state">code</field>
            <field name="code">model._cron_collect_server_metrics()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Auto-stop: stop staging/dev instances after 1h inactivity -->
        <record model="ir.cron" id="cron_auto_stop">
            <field name="name">PMB DevOps: Auto-stop instancias inactivas</field>
            <field name="model_id" ref="pmb_devops.model_devops_instance"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_stop()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Auto-destroy: destroy stopped development instances after configured hours -->
        <record model="ir.cron" id="cron_auto_destroy">
            <field name="name">PMB DevOps: Auto-destroy development inactivas</field>
            <field name="model_id" ref="pmb_devops.model_devops_instance"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_destroy()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <!-- Watchdog: relaunch stuck creation scripts every 2 min -->
        <record model="ir.cron" id="cron_creation_watchdog">
            <field name="name">PMB DevOps: Watchdog creacion instancias</field>
            <field name="model_id" ref="pmb_devops.model_devops_instance"/>
            <field name="state">code</field>
            <field name="code">model._cron_creation_watchdog()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Health check: check all running instances every 5 min -->
        <record model="ir.cron" id="cron_health_check">
            <field name="name">PMB DevOps: Health check instancias</field>
            <field name="model_id" ref="pmb_devops.model_devops_instance"/>
            <field name="state">code</field>
            <field name="code">model._cron_health_check()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>
        <!-- Cleanup: failed/stuck instances every 6 hours -->
        <record model="ir.cron" id="cron_cleanup_failed">
            <field name="name">PMB DevOps: Limpiar instancias fallidas</field>
            <field name="model_id" ref="pmb_devops.model_devops_instance"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_failed()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>
        <!-- AI Agents: run due agents every 30 min -->
        <record model="ir.cron" id="cron_ai_agents">
            <field name="name">PMB DevOps: Ejecutar agentes IA</field>
            <field name="model_id" ref="pmb_devops.model_devops_ai_agent"/>
            <field name="state">code</field>
            <field name="code">model._cron_run_agents()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Pull remote tasks from production Odoo into pmb_devops every 5 min -->
        <record model="ir.cron" id="cron_pull_remote_tasks">
            <field name="name">PMB DevOps: Pull tareas desde producción</field>
            <field name="model_id" ref="pmb_devops.model_devops_project"/>
            <field name="state">code</field>
            <field name="code">model._cron_pull_remote_tasks()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
