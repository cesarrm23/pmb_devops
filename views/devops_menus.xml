<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main SPA action -->
    <record id="action_devops_main" model="ir.actions.client">
        <field name="name">PatchMyByte DevOps</field>
        <field name="tag">pmb_devops_main</field>
    </record>

    <!-- Root menu — opens SPA -->
    <menuitem id="menu_devops_root"
              name="DevOps"
              web_icon="pmb_devops,static/description/icon.svg"
              sequence="95"
              action="action_devops_main"
              groups="pmb_devops.group_devops_viewer"/>

    <!-- Admin-only configuration submenu -->
    <menuitem id="menu_devops_config"
              name="Configuración"
              parent="menu_devops_root"
              sequence="100"
              groups="pmb_devops.group_devops_admin"/>

    <menuitem id="menu_devops_settings"
              name="Ajustes"
              parent="menu_devops_config"
              action="action_devops_settings"
              sequence="10"/>

    <menuitem id="menu_devops_instances"
              name="Instancias (Admin)"
              parent="menu_devops_config"
              action="action_devops_instance"
              sequence="20"/>

    <!-- Keep existing project/branch/build actions for fallback -->
    <menuitem id="menu_devops_projects_admin"
              name="Proyectos (Admin)"
              parent="menu_devops_config"
              action="action_devops_project"
              sequence="30"/>

    <!-- Documentation -->
    <record id="action_devops_manual" model="ir.actions.act_url">
        <field name="name">Manual de Usuario</field>
        <field name="url">/pmb_devops/static/description/manual/index.html</field>
        <field name="target">new</field>
    </record>
    <menuitem id="menu_devops_docs"
              name="Documentación"
              parent="menu_devops_config"
              action="action_devops_manual"
              sequence="40"/>
</odoo>
