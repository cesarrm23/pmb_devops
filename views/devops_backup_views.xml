<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Action                                                        -->
    <!-- ============================================================ -->
    <record id="action_devops_backup" model="ir.actions.act_window">
        <field name="name">Backups</field>
        <field name="res_model">devops.backup</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay backups registrados
            </p>
            <p>Crea un backup desde un proyecto o configura backups automaticos.</p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- List view                                                     -->
    <!-- ============================================================ -->
    <record id="view_devops_backup_list" model="ir.ui.view">
        <field name="name">devops.backup.list</field>
        <field name="model">devops.backup</field>
        <field name="arch" type="xml">
            <list string="Backups"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'failed'"
                  decoration-info="state == 'running'"
                  decoration-muted="state == 'pending'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'failed'"
                       decoration-info="state == 'running'"
                       decoration-muted="state == 'pending'"/>
                <field name="backup_type"/>
                <field name="trigger"/>
                <field name="file_size"/>
                <field name="database_name"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Form view                                                     -->
    <!-- ============================================================ -->
    <record id="view_devops_backup_form" model="ir.ui.view">
        <field name="name">devops.backup.form</field>
        <field name="model">devops.backup</field>
        <field name="arch" type="xml">
            <form string="Backup">
                <header>
                    <button name="action_run_backup" type="object"
                            string="Run Backup" class="oe_highlight"
                            icon="fa-play"
                            invisible="state not in ('pending', 'failed')"/>
                    <button name="action_restore" type="object"
                            string="Restore" icon="fa-undo"
                            class="btn-warning"
                            invisible="state != 'done'"
                            confirm="Restaurar este backup? Esto mostrara instrucciones."/>
                    <button name="action_download" type="object"
                            string="Download" icon="fa-download"
                            invisible="state != 'done'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,running,done,failed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Informacion del Backup">
                            <field name="project_id"/>
                            <field name="backup_type"/>
                            <field name="trigger"/>
                            <field name="database_name"/>
                            <field name="created_by"/>
                        </group>
                        <group string="Archivo">
                            <field name="file_path"/>
                            <field name="file_size"/>
                        </group>
                    </group>
                    <group>
                        <group string="Tiempos">
                            <field name="started_at"/>
                            <field name="finished_at"/>
                            <field name="duration"/>
                        </group>
                        <group string="Notas">
                            <field name="notes"/>
                        </group>
                    </group>
                    <group invisible="not error_message">
                        <field name="error_message" readonly="1"
                               string="Mensaje de Error"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Search view                                                   -->
    <!-- ============================================================ -->
    <record id="view_devops_backup_search" model="ir.ui.view">
        <field name="name">devops.backup.search</field>
        <field name="model">devops.backup</field>
        <field name="arch" type="xml">
            <search string="Backups">
                <field name="name"/>
                <field name="project_id"/>
                <field name="database_name"/>
                <separator/>
                <filter string="Pendiente" name="filter_pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter string="En Progreso" name="filter_running"
                        domain="[('state', '=', 'running')]"/>
                <filter string="Completado" name="filter_done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="Fallido" name="filter_failed"
                        domain="[('state', '=', 'failed')]"/>
                <separator/>
                <filter string="Manual" name="filter_manual"
                        domain="[('trigger', '=', 'manual')]"/>
                <filter string="Cron" name="filter_cron"
                        domain="[('trigger', '=', 'cron')]"/>
                <filter string="Pre-Deploy" name="filter_pre_deploy"
                        domain="[('trigger', '=', 'pre_deploy')]"/>
                <separator/>
                <filter string="Completo" name="filter_full"
                        domain="[('backup_type', '=', 'full')]"/>
                <filter string="Solo SQL" name="filter_sql"
                        domain="[('backup_type', '=', 'sql')]"/>
                <filter string="Solo Filestore" name="filter_filestore"
                        domain="[('backup_type', '=', 'filestore')]"/>
            </search>
        </field>
    </record>

</odoo>
