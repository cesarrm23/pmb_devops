<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- AI Assistant Wizard — Form view                               -->
    <!-- ============================================================ -->
    <record id="view_devops_ai_assistant_wizard_form" model="ir.ui.view">
        <field name="name">devops.ai.assistant.wizard.form</field>
        <field name="model">devops.ai.assistant.wizard</field>
        <field name="arch" type="xml">
            <form string="Asistente IA">

                <!-- ── State: INPUT ─────────────────────────────── -->
                <group invisible="state != 'input'">
                    <group>
                        <field name="project_id"/>
                        <field name="context_type"/>
                        <field name="use_claude_code_cli"/>
                    </group>
                    <group>
                        <field name="include_recent_logs"/>
                        <field name="include_git_status"/>
                        <field name="include_last_build"/>
                    </group>
                    <group colspan="2">
                        <field name="prompt" widget="html"
                               options="{'resizable': true}"
                               placeholder="Escribe tu consulta aqui. Pega imágenes (Ctrl+V), agrega tablas, callouts de /banner-info, /banner-warning, etc."
                               nolabel="1" colspan="2"/>
                    </group>
                </group>

                <!-- ── State: PROCESSING ────────────────────────── -->
                <div invisible="state != 'processing'" class="text-center py-5">
                    <i class="fa fa-spinner fa-spin fa-3x text-primary mb-3" title="Procesando"/>
                    <h3>Procesando consulta...</h3>
                    <p class="text-muted">
                        Enviando prompt a Claude. Esto puede tomar unos segundos.
                    </p>
                </div>

                <!-- ── State: RESULT ────────────────────────────── -->
                <group invisible="state != 'result'">
                    <!-- Error alert -->
                    <div invisible="not error_message" colspan="2"
                         class="alert alert-danger" role="alert">
                        <strong>Error:</strong>
                        <field name="error_message" nolabel="1" readonly="1"/>
                    </div>
                    <!-- Response -->
                    <group colspan="2">
                        <field name="response_html" nolabel="1" colspan="2"
                               readonly="1"/>
                    </group>
                    <!-- Metadata -->
                    <group>
                        <field name="tokens_used" readonly="1"/>
                    </group>
                    <group>
                        <field name="duration" readonly="1" widget="float_time"/>
                    </group>
                </group>

                <!-- ── History (always visible when project selected) ── -->
                <group string="Historial reciente (ultimas 10 consultas)"
                       invisible="not project_id" colspan="2">
                    <field name="history_ids" nolabel="1" colspan="2">
                        <list create="0" delete="0" edit="0">
                            <field name="name"/>
                            <field name="context_type" widget="badge"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'done'"
                                   decoration-danger="state == 'error'"
                                   decoration-warning="state == 'sending'"
                                   decoration-muted="state == 'draft'"/>
                            <field name="model_used"/>
                            <field name="tokens_used"/>
                            <field name="create_date"/>
                        </list>
                    </field>
                </group>

                <field name="state" invisible="1"/>

                <footer>
                    <!-- Input state: Send button -->
                    <button name="action_send" type="object"
                            string="Enviar" class="btn-primary"
                            icon="fa-paper-plane"
                            invisible="state != 'input'"/>
                    <!-- Result state: New Question + Close -->
                    <button name="action_new_question" type="object"
                            string="Nueva Consulta" class="btn-primary"
                            icon="fa-plus"
                            invisible="state != 'result'"/>
                    <button string="Cerrar" class="btn-secondary"
                            special="cancel"
                            invisible="state == 'processing'"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- AI Assistant Wizard — Action                                  -->
    <!-- ============================================================ -->
    <record id="action_devops_ai_assistant_wizard" model="ir.actions.act_window">
        <field name="name">Asistente IA</field>
        <field name="res_model">devops.ai.assistant.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
